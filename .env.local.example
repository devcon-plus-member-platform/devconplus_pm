# ─── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Public keys — safe to expose in browser
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# Secret key — NEVER expose in browser or commit to git
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret-key>

# ─── Resend (email) ───────────────────────────────────────────────────────────
# Sign up at resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
# Create a bot via @BotFather, get the token
TELEGRAM_BOT_TOKEN=0000000000:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# The chat_id of the DEVCON+ group where announcements are broadcast
TELEGRAM_GROUP_CHAT_ID=-100xxxxxxxxxx
# Optional: secret token to verify webhook requests (set when registering webhook)
# openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=your_random_secret_here

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
